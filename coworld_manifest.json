{
  "$schema": "https://raw.githubusercontent.com/Metta-AI/metta/main/packages/coworld/src/coworld/coworld_manifest_schema.json",
  "game": {
    "name": "planet_wars",
    "version": "0.1.0",
    "description": "A BitWorld strategy game where players conquer planets and launch ships across a tiny star map.",
    "owner": "treeform@softmax.com",
    "config_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tokens"
      ],
      "properties": {
        "tokens": {
          "description": "One connection token per player slot, indexed by slot.",
          "type": "array",
          "minItems": 0,
          "maxItems": 16,
          "items": {
            "type": "string",
            "minLength": 0
          },
          "default": []
        },
        "seed": {
          "description": "Random seed.",
          "type": "integer",
          "minimum": 0,
          "default": 108519
        },
        "planetCount": {
          "description": "Number of planets to place in the world.",
          "type": "integer",
          "minimum": 1,
          "maximum": 48,
          "default": 47
        },
        "maxTicks": {
          "description": "Maximum ticks per game, where 18000 is about five minutes at 60 Hz and 0 disables the tick limit.",
          "type": "integer",
          "minimum": 0,
          "default": 18000
        },
        "maxGames": {
          "description": "Maximum games before shutdown, where 0 means infinite.",
          "type": "integer",
          "minimum": 0,
          "default": 0
        }
      }
    },
    "results_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "names",
        "scores",
        "win",
        "planets",
        "ships"
      ],
      "properties": {
        "names": {
          "description": "One player name or address per player slot.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "scores": {
          "description": "One strategy score per player slot.",
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          }
        },
        "win": {
          "description": "One win flag per player slot.",
          "type": "array",
          "items": {
            "type": "boolean"
          }
        },
        "planets": {
          "description": "One owned planet count per player slot.",
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          }
        },
        "ships": {
          "description": "One total owned ship count per player slot.",
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "protocols": {
      "player": {
        "type": "uri",
        "value": "https://github.com/Metta-AI/bitworld/blob/master/docs/sprite_v1.md"
      },
      "global": {
        "type": "uri",
        "value": "https://github.com/Metta-AI/bitworld/blob/master/docs/sprite_v1.md"
      }
    },
    "docs": {
      "readme": {
        "type": "uri",
        "value": "https://github.com/Metta-AI/coworld-planet-wars/blob/main/README.md"
      },
      "pages": [
        {
          "id": "rules.md",
          "title": "rules.md",
          "content": {
            "type": "text",
            "value": "# Planet Wars Rules\n\nPlayers conquer planets and launch ships across a small star map. Neutral planets can be captured by sending enough ships. Owned planets grow more ships over time. A player wins when every remaining active planet and ship belongs to them. If the tick limit is reached first, the game ends with no winner."
          }
        },
        {
          "id": "play_planet_wars.md",
          "title": "play_planet_wars.md",
          "content": {
            "type": "uri",
            "value": "https://github.com/Metta-AI/coworld-planet-wars/blob/main/README.md"
          }
        },
        {
          "id": "reward.md",
          "title": "reward.md",
          "content": {
            "type": "uri",
            "value": "https://github.com/Metta-AI/bitworld/blob/master/docs/reward_v1.md"
          }
        }
      ]
    },
    "runnable": {
      "type": "game",
      "image": "public.ecr.aws/s3j4p9s7/treeform/games/planet-wars:latest",
      "run": ["/bin/planet_wars"]
    }
  },
  "player": [
    {
      "id": "skurge",
      "type": "player",
      "name": "Skurge",
      "description": "Sprite-protocol Planet Wars attacker that learns its color and slowly pressures visible planets.",
      "image": "public.ecr.aws/s3j4p9s7/treeform/players/skurge:latest",
      "run": ["/bin/skurge"]
    }
  ],
  "reporter": [
    {
      "id": "default-reporter",
      "type": "reporter",
      "name": "Default Reporter",
      "description": "Default Coworld reporter for generic episode artifacts.",
      "image": "public.ecr.aws/q5f4m8t9/cogames@sha256:396e56a9ba1576aecc5b9868a85fa309ea98fdbbf8d656c94ec021906197ea52"
    }
  ],
  "grader": [
    {
      "id": "bitworld-score-grader",
      "name": "BitWorld Score Grader",
      "type": "grader",
      "description": "Generic BitWorld grader that scores episode interest from score spread and game-specific activity signals.",
      "source_url": "https://github.com/Metta-AI/graders/tree/main/graders/bitworld_score/bitworld_score_grader",
      "image": "ghcr.io/metta-ai/graders-bitworld-score:latest"
    }
  ],
  "variants": [
    {
      "id": "smoke",
      "name": "Smoke",
      "game_config": {
        "seed": 108519,
        "planetCount": 47,
        "maxTicks": 1200,
        "maxGames": 0
      },
      "description": "Short deterministic Planet Wars configuration used for manifest checks."
    }
  ],
  "certification": {
    "game_config": {
      "seed": 108519,
      "planetCount": 47,
      "maxTicks": 1200,
      "maxGames": 0
    },
    "players": [
      {
        "player_id": "skurge"
      },
      {
        "player_id": "skurge"
      }
    ]
  }
}
